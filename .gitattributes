# Default: normalize line endings on commit, leave alone on checkout.
* text=auto

# Source code: enforce LF on commit (we work cross-platform).
*.c       text eol=lf
*.cc      text eol=lf
*.cpp     text eol=lf
*.h       text eol=lf
*.hpp     text eol=lf
*.py      text eol=lf
*.cmake   text eol=lf
*.txt     text eol=lf
*.md      text eol=lf
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
CMakeLists.txt text eol=lf

# Windows-only project files: keep CRLF.
*.sln     text eol=crlf
*.vcxproj text eol=crlf
*.props   text eol=crlf
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# Binary — never diff or merge.
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.zip     binary
*.7z      binary
*.bin     binary

# Diff hints for non-obvious extensions.
*.asi     binary
*.idc     text
